# Development Dockerfile — hot-reload with tsx watch
# The docker-compose volume mount overlays the host source tree so edits
# are reflected immediately without a rebuild.

FROM node:22-alpine

WORKDIR /app

# Install pnpm
RUN corepack enable && corepack prepare pnpm@latest --activate

# Copy manifests and install (node_modules will be shadowed by volume mount
# only for source; the anonymous volume in compose keeps node_modules intact)
COPY package.json pnpm-lock.yaml* ./
RUN pnpm install

# Copy source (overridden by volume mount in docker-compose, but included
# here so the image is self-contained if run standalone)
COPY tsconfig.json ./
COPY src/ ./src/

EXPOSE 4000

ENV NODE_ENV=development \
    PORT=4000

CMD ["pnpm", "run", "dev"]
