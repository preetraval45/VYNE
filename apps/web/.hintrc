{
  "extends": ["development"],
  "hints": {
    "no-inline-styles": "off",
    "compat-api/css": "off",
    "compat-api/html": "off",
    "disown-opener": "off",
    "meta-viewport": "off",
    "meta-charset-utf-8": "off",
    "meta-theme-color": "off",
    "highest-available-document-mode": "off",
    "no-html-only-headers": "off",
    "no-http-redirects": "off",
    "no-vulnerable-javascript-libraries": "off",
    "sri": "off",
    "ssllabs": "off",
    "content-type": "off",
    "http-cache": "off",
    "http-compression": "off",
    "https-only": "off",
    "manifest-exists": "off",
    "manifest-file-extension": "off",
    "manifest-icons": "off",
    "manifest-is-valid": "off",
    "apple-touch-icons": "off",
    "validate-set-cookie-header": "off",
    "x-content-type-options": "off",
    "strict-transport-security": "off",
    "no-disallowed-headers": "off",
    "create-element-svg": "off",
    "no-broken-links": "off",
    "no-protocol-relative-urls": "off",
    "stylesheet-limits": "off",
    "detect-css-reflows/composite": "off",
    "detect-css-reflows/layout": "off",
    "detect-css-reflows/paint": "off",
    "button-type": "off",
    "axe/aria": "off",
    "axe/keyboard": "off"
  }
}
