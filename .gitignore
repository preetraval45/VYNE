terraform.rc
.terraform.lock.hcl

# ── AWS ──────────────────────────────────────────────────────
.aws/credentials
.aws-sam/

# ── OS ───────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
