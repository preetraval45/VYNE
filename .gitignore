# ============================================================
# VYNE — Comprehensive .gitignore
# Node + Python + .NET + Docker + Terraform + Secrets
# ============================================================

# ── Secrets & Environment Variables ──────────────────────────
.env
.env.local
.env.*.local
.env.development
.env.staging
.env.production
*.pem
*.key
*.cert
*.p12
*.pfx
secrets/
.secrets/

# ── Node.js ──────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
.npm/
.yarn/

# ── Next.js ──────────────────────────────────────────────────
.next/
out/
.vercel/

# ── TypeScript ───────────────────────────────────────────────
*.tsbuildinfo
dist/
build/

# ── Turborepo ────────────────────────────────────────────────
.turbo/

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
.env/
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
dist/
.eggs/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# ── .NET / C# ────────────────────────────────────────────────
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/
*.user
*.suo
*.userosscache
*.sln.docstates
.vs/
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user
TestResults/
