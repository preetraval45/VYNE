# ============================================================
# VYNE — Environment Variables Template
# Copy to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000
API_GATEWAY_URL=http://localhost:4000

# ── Database (PostgreSQL / Aurora) ───────────────────────────
DATABASE_URL=postgresql://vyne:vyne_dev_password@localhost:5432/vyne_dev
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=vyne_dev
DATABASE_USER=vyne
DATABASE_PASSWORD=vyne_dev_password
DATABASE_SSL=false
# For production, loaded from AWS Secrets Manager:
# DATABASE_SECRET_ARN=arn:aws:secretsmanager:us-east-1:ACCOUNT_ID:secret:vyne/prod/database

# ── Redis / ElastiCache (Valkey) ─────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# For production:
# REDIS_SECRET_ARN=arn:aws:secretsmanager:us-east-1:ACCOUNT_ID:secret:vyne/prod/redis

# ── AWS (General) ────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=YOUR_AWS_ACCOUNT_ID
# For local dev, use AWS CLI profile. For ECS, uses task role.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── AWS Cognito (Auth) ───────────────────────────────────────
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX
COGNITO_REGION=us-east-1
COGNITO_DOMAIN=vyne-dev.auth.us-east-1.amazoncognito.com
NEXTAUTH_SECRET=your_nextauth_secret_min_32_chars_here
NEXTAUTH_URL=http://localhost:3000

# ── AWS Bedrock (AI) ─────────────────────────────────────────
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

# ── AWS EventBridge ──────────────────────────────────────────
EVENTBRIDGE_BUS_NAME=vyne-events
EVENTBRIDGE_REGION=us-east-1

# ── AWS SQS ──────────────────────────────────────────────────
SQS_ERP_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/ACCOUNT_ID/vyne-erp.fifo
SQS_MESSAGING_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/ACCOUNT_ID/vyne-messaging.fifo
SQS_NOTIFICATIONS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/ACCOUNT_ID/vyne-notifications.fifo
SQS_AI_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/ACCOUNT_ID/vyne-ai.fifo

# ── AWS S3 ───────────────────────────────────────────────────
S3_FILES_BUCKET=vyne-files-dev
S3_REGION=us-east-1

# ── AWS SES (Email) ──────────────────────────────────────────
SES_FROM_EMAIL=noreply@vyne.io
SES_REGION=us-east-1

# ── AWS SNS (Push Notifications) ─────────────────────────────
SNS_PUSH_TOPIC_ARN=arn:aws:sns:us-east-1:ACCOUNT_ID:vyne-push-notifications

# ── AWS Secrets Manager ──────────────────────────────────────
SECRETS_MANAGER_REGION=us-east-1

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_min_64_chars_here_use_openssl_rand_hex_64
JWT_EXPIRES_IN=7d

# ── Services (internal ports for local dev) ──────────────────
CORE_SERVICE_URL=http://localhost:5001
PROJECTS_SERVICE_URL=http://localhost:5002
MESSAGING_SERVICE_URL=http://localhost:5003
AI_SERVICE_URL=http://localhost:5004
ERP_SERVICE_URL=http://localhost:5005
OBSERVABILITY_SERVICE_URL=http://localhost:5006
NOTIFICATION_SERVICE_URL=http://localhost:5007

# ── WebSocket ────────────────────────────────────────────────
WEBSOCKET_URL=ws://localhost:4000
SOCKET_IO_CORS_ORIGIN=http://localhost:3000

# ── Stripe (Billing) ─────────────────────────────────────────
STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXX
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXX

# ── GitHub App (DevOps integration) ──────────────────────────
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# ── OpenTelemetry ────────────────────────────────────────────
OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=vyne-local
OTEL_EXPORTER_OTLP_HEADERS=

# ── Next.js (public vars — safe to expose to browser) ────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000
NEXT_PUBLIC_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
NEXT_PUBLIC_COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_COGNITO_REGION=us-east-1
NEXT_PUBLIC_S3_BUCKET=vyne-files-dev
NEXT_PUBLIC_APP_ENV=development

# ── Feature Flags ────────────────────────────────────────────
FEATURE_AI_ENABLED=true
FEATURE_ERP_ENABLED=true
FEATURE_OBSERVABILITY_ENABLED=true
FEATURE_MOBILE_PUSH_ENABLED=false

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
MESSAGING_RATE_LIMIT_PER_MIN=60
